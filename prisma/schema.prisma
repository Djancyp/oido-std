generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Role {
  id          String   @id
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  users       UserRole[]
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles        UserRole[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
}
